# Upload backend endpoint
UPLOAD_BASE_URL=http://1080.alpen-y.top:8080
UPLOAD_PATH=/api/v1/slam/upload

# Self-use simple auth token (must match backend AUTH_TOKENS)
UPLOAD_AUTH_TOKEN=slam-self-use-token

# Optional tuning (seconds)
UPLOAD_CONNECT_TIMEOUT_SECONDS=10
UPLOAD_SEND_TIMEOUT_SECONDS=600
UPLOAD_RECEIVE_TIMEOUT_SECONDS=60

# Optional queue tuning
UPLOAD_MAX_RETRY_ATTEMPTS=3
UPLOAD_RETRY_BASE_DELAY_SECONDS=2
UPLOAD_MAX_HISTORY_ITEMS=40
